# Copy to .env and fill in when credentials are available.
# Until CWA_API_KEY is set, the backend runs in MOCK mode and serves fixture data,
# so the whole app is runnable end-to-end without any credentials.

# CWA (Central Weather Administration) open-data authorization key (CWA-xxxxxxxx)
# Get one free at https://opendata.cwa.gov.tw
CWA_API_KEY=

# TDX (Transport Data eXchange) OAuth2 client credentials (Phase 2/3).
# Register free at https://tdx.transportdata.tw/register
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# Gemini API key for AI trip summary (Phase 1 enhancement).
# When empty, a deterministic rule-based summary is used instead (graceful degrade).
GEMINI_API_KEY=

# Cache TTL in seconds for forecast lookups.
CACHE_TTL_SECONDS=1800

# Comma-separated allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
