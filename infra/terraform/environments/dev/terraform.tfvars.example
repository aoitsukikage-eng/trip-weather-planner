resource_group_name            = "rg-twp-demo"
location                       = "southeastasia"
container_registry_name        = "twpacr4316"
log_analytics_workspace_name   = "twp-log-analytics"
container_app_environment_name = "twp-ca-env"
container_app_name             = "twp-backend"
backend_image                  = "twpacr4316.azurecr.io/twp-backend:latest"
frontend_storage_account_name  = "twpfe5ce0"
frontend_origin                = "https://twpfe5ce0.z23.web.core.windows.net"

cache_ttl_seconds        = 1800
upstream_timeout_seconds = 10
min_replicas             = 0
max_replicas             = 1
cpu                      = 0.5
memory                   = "1Gi"
target_port              = 8080

# Provide this value through TF_VAR_cwa_api_key or an uncommitted local tfvars
# file. Do not commit real API keys.
# cwa_api_key = "<CWA_API_KEY>"
